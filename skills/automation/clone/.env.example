# clone — example env. COPY to your project's .env (gitignored) and fill in. NEVER commit the real .env.
# The skill adds `.env` and `.clone/` to your project's .gitignore before writing any of this.

# REQUIRED — your Telegram bot token from @BotFather. The ONLY home for this secret.
TELEGRAM_BOT_TOKEN=

# RECOMMENDED — lock the bot to your chat. Leave blank and send /start once to pair, then fill this in.
CLONE_OWNER_CHAT_ID=

# REQUIRED — SSH url of the PRIVATE repo named `clone` you created (the brain). e.g. git@github.com:you/clone.git
CLONE_REPO_SSH=

# OPTIONAL
CLONE_BRAIN_PATH=.clone/brain      # where the brain repo is checked out
CLONE_LANG=en                      # language for system notices (e.g. en, fa)
CLONE_MODEL=                       # pass --model to claude (blank = your CLI default)
CLONE_OWNER_NAME=                  # your name, used when scaffolding the brain
CLONE_CLAUDE_CMD=claude            # the Claude Code binary
CLONE_TURN_TIMEOUT=600             # seconds before a stuck turn is killed
